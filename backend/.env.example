PORT=4000
HOSTNAME=localhost
NODE_ENV=development
SSL=false
SSL_KEY_PATH=""
SSL_CERT_PATH=""

MONGODB_URL='mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<appName>'

JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# Default admin (seeded on first boot if no admin account exists)
ADMIN_EMAIL=admin@videoconference.com
ADMIN_PASSWORD=change-me

# Comma-separated allowed origins (conference app + admin app)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
APP_NAME=Video Conference

# Email (Zoho Mail SMTP — free tier). Leave SMTP_USER/SMTP_PASS blank to disable emails.
# Zoho: host smtp.zoho.com (or smtp.zoho.in for .in accounts), port 465 (SSL).
# If 2FA is on, create an app-specific password in Zoho and use it as SMTP_PASS.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-zoho-email@yourdomain.com
SMTP_PASS=your-zoho-app-password
SMTP_FROM=Video Conference <no-reply@yourdomain.com>
