PORT=4000
HOSTNAME=localhost
NODE_ENV=development
SSL=false
SSL_KEY_PATH=""
SSL_CERT_PATH=""

MONGODB_URL='mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<appName>'

JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h

# Default admin (seeded on first boot if no admin account exists)
ADMIN_EMAIL=admin@videoconference.com
ADMIN_PASSWORD=change-me

# Comma-separated allowed origins (conference app + admin app)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
APP_NAME=Video Conference
